generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                  Int      @id @default(1)
  name                String   @default("Braden")
  weightLbs           Float
  heightStr           String
  age                 Int
  sex                 String
  benchMaxLbs         Float?
  squatMaxLbs         Float?
  deadliftMaxLbs      Float?
  ohpMaxLbs           Float?
  legPressMaxLbs      Float?
  tbarRowWeightLbs    Float?
  trainingDaysPerWeek Int
  sessionLengthMin    Int
  equipment           String
  primaryGoal         String
  secondaryGoal       String?
  injuryNotes         String?  @db.Text
  restrictedMovements String?  @db.Text
  availableEquipment  String   @default("[]") @db.Text
  nutritionPhase      String?
  dailyCalorieTarget  Int?
  proteinTargetG      Int?
  carbTargetG         Int?
  fatTargetG          Int?
  mealsPerDay         Int?
  nutritionNotes      String?  @db.Text
  nutritionCalculated Boolean  @default(false)

  // Food preferences
  favoriteMeals       String?  @db.Text
  hatedFoods          String?  @db.Text
  dietaryRestrictions String?  @db.Text
  cookingStyle        String?
  foodAdventurousness Int?

  // Snack habits
  currentSnacks       String?  @db.Text
  snackReason         String?
  snackPreference     String?
  lateNightSnacking   Boolean?

  // Lifestyle baseline
  jobType              String?
  typicalSleepHours    Float?
  baselineStressLevel  String?
  alcoholDrinksPerWeek Int?
  dailyStepTarget      Int?

  nutritionOnboarded  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Program {
  id          Int              @id @default(autoincrement())
  name        String
  weeks       Int              @default(12)
  promptType  String           @default("program")
  content     String           @db.Text
  isActive    Boolean          @default(true)
  startDate   DateTime?
  createdAt   DateTime         @default(now())
  sessions    WorkoutSession[]
}

model WorkoutSession {
  id          Int           @id @default(autoincrement())
  programId   Int?
  program     Program?      @relation(fields: [programId], references: [id])
  week        Int?
  day         Int?
  sessionName String?
  date        DateTime      @default(now())
  completed   Boolean       @default(false)
  durationMin Int?
  notes       String?       @db.Text
  exercises   ExerciseLog[]
}

model ExerciseLog {
  id            Int            @id @default(autoincrement())
  sessionId     Int
  session       WorkoutSession @relation(fields: [sessionId], references: [id])
  exerciseName  String
  muscleGroup   String?
  sets          Int
  reps          Int
  weightLbs     Float
  rpe           Float?
  tempo         String?
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
}

model WeeklyCheckIn {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  weekNumber      Int?
  bodyweightLbs   Float
  photoTaken      Boolean  @default(false)
  sleepHours      Float
  sleepQuality    Int
  stressLevel     String
  energyScore     Int
  recoveryScore   Int
  avgCalories     Int?
  avgProteinG     Int?
  nutritionNotes  String?  @db.Text
  wins            String?  @db.Text
  struggles       String?  @db.Text
  notes           String?  @db.Text
}

model PlateauLog {
  id            Int       @id @default(autoincrement())
  detectedAt    DateTime  @default(now())
  exerciseName  String
  stalledWeeks  Int
  lastWeight    Float
  aiAnalysis    String?   @db.Text
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedNotes String?   @db.Text
}

model AIResponse {
  id          Int      @id @default(autoincrement())
  promptType  String
  inputData   String?  @db.Text
  content     String   @db.Text
  model       String   @default("claude-sonnet-4-6")
  createdAt   DateTime @default(now())
}

model NutritionPlan {
  id            Int      @id @default(autoincrement())
  programId     Int?
  phase         String
  dailyCalories Int
  proteinG      Int
  carbsG        Int
  fatG          Int
  mealPlan      String   @db.Text
  snackSwaps    String?  @db.Text
  personalRules String?  @db.Text
  timeline      String?  @db.Text
  hydration     String?  @db.Text
  supplements   String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}
